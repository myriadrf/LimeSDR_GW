name: Upload Recursive Zip to Release

# Trigger this only when a Release is published
on:
  release:
    types: [published]

jobs:
  build-and-upload:
    runs-on: ubuntu-latest
    steps:
      # 1. Checkout code INCLUDING submodules
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          submodules: recursive
          path: ${{ github.event.repository.name }}

      # 2. Create the Source Zip file
      # Content: The entire repo folder
      - name: Zip the Source directory
        run: |
          zip -r ${{ github.event.repository.name }}_${{ github.ref_name }}.zip ${{ github.event.repository.name }} -x "*.git*"

      # 3. Create the Bitstream Zip file
      # Content: Only the 'bitstream' folder inside the repo
      - name: Zip the Bitstream directory
        run: |
          zip -r ${{ github.event.repository.name }}_${{ github.ref_name }}_bitstream.zip ${{ github.event.repository.name }}/bitstream

      # 4. Upload BOTH Zip files to the Release page
      - name: Upload to Release
        uses: softprops/action-gh-release@v1
        if: startsWith(github.ref, 'refs/tags/')
        with:
          # We use the pipe (|) to list multiple files
          files: |
            ${{ github.event.repository.name }}_${{ github.ref_name }}.zip
            ${{ github.event.repository.name }}_${{ github.ref_name }}_bitstream.zip
